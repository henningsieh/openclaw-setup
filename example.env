# Example environment variables for openclaw-setup
# Copy this file to .env and fill in secret values. .env is gitignored and should never be committed.

# Base image / version (non-secret)
OPENCLAW_VERSION=2026.4.11
OPENCLAW_IMAGE=openclaw-local

# Runtime flags (non-secret)
OPENCLAW_NO_RESPAWN=1
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789

# Paths (non-sensitive)
OPENCLAW_CONFIG_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
OPENCLAW_BUNDLED_PLUGINS_DIR=/app/dist/extensions
STAGED_SKILLS_DIR=/opt/openclaw-skills-default/skills
LIVE_SKILLS_DIR=/home/node/.openclaw/skills
NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
XDG_CONFIG_HOME=/home/node/.openclaw

# Secrets (REDACTED) — clear here. Put real values only in your local .env (which is ignored).
OPENCLAW_GATEWAY_TOKEN=
GATEWAY_AUTH_PASSWORD=
GOG_KEYRING_PASSWORD=
TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
COPILOT_GITHUB_TOKEN=
OPENROUTER_API_KEY=
NVIDIA_NVIM_API_KEY=

# Notes:
# - Do not commit real secrets. Keep .env in .gitignore.
# - After filling .env, restart containers: `docker compose up -d --build`.
# - For production, prefer a secrets manager or environment injection in your host/CI.
