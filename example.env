# Example environment variables for openclaw-setup
# Copy this file to .env and fill in secret values. .env is gitignored and should never be committed.

# Base image / version (non-secret)
OPENCLAW_VERSION=2026.4.11
OPENCLAW_IMAGE=openclaw-local

# Runtime flags (non-secret)
OPENCLAW_NO_RESPAWN=1
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789

# Paths (non-sensitive)
OPENCLAW_CONFIG_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
OPENCLAW_BUNDLED_PLUGINS_DIR=/app/dist/extensions
STAGED_SKILLS_DIR=/opt/openclaw-skills-default/skills
LIVE_SKILLS_DIR=/home/node/.openclaw/skills
NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
XDG_CONFIG_HOME=/home/node/.openclaw

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Values are blank here (example/template). Put real values only in your local
# .env (which is gitignored and must never be committed).

# OpenClaw gateway bearer token — choose any strong random string.
# Generate one with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw web UI password — choose any strong passphrase.
GATEWAY_AUTH_PASSWORD=

# Keyring encryption password — used to unlock the GOG/secret-service keyring
# inside the container. Choose any strong passphrase and keep it consistent
# across restarts (changing it will lock you out of stored secrets).
GOG_KEYRING_PASSWORD=

# Telegram bot token — obtained from @BotFather on Telegram.
# Start a chat with @BotFather, send /newbot, follow the prompts.
# Result looks like: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_TOKEN=

# Discord bot token — obtained from the Discord Developer Portal.
# Go to https://docs.openclaw.ai/channels/discord#quick-setup
# Create an application, add a bot, copy the token, and invite it to your server.
DISCORD_BOT_TOKEN=

# Google Gemini API key — obtain at https://aistudio.google.com/apikey
# No credit card required for the free tier.
GEMINI_API_KEY=

# GitHub Copilot token — required if using the Copilot AI provider.
#
# Option A — via gh CLI (easiest if already authenticated):
#   Check current auth and scopes:
#     gh auth status
#   If the `copilot` scope is missing, re-authenticate:
#     gh auth login --scopes "copilot,read:user"
#   Then print the token:
#     gh auth token
#
# Option B — classic Personal Access Token (PAT) on github.com:
#   https://github.com/settings/tokens → Generate new token (classic)
#   Required scopes: copilot, read:user
#   Note: fine-grained tokens do NOT support Copilot — use classic tokens only.
#
# Option C — let OpenClaw do the OAuth flow for you:
#   Run: openclaw gateway install   (or the onboarding wizard)
#   OpenClaw will store the token in your config; copy it from there.
#
# The token typically looks like: ghu_... or ghp_...
COPILOT_GITHUB_TOKEN=

# OpenRouter API key — obtain at https://openrouter.ai/keys
# Provides access to many models (OpenAI, Anthropic, Mistral, etc.) via one key.
OPENROUTER_API_KEY=

# NVIDIA NIM API key — obtain at https://build.nvidia.com
# Required for NVIDIA-hosted model inference endpoints.
NVIDIA_NVIM_API_KEY=

# ─── Notes ────────────────────────────────────────────────────────────────────
# - Do not commit real secrets. Keep .env in .gitignore.
# - After filling .env, restart containers: `docker compose up -d --build`.
# - For production, prefer a secrets manager or environment injection in your host/CI.
