# Example environment variables for openclaw-setup
# Copy this file to .env and fill in secret values. 
# The `.env` file is gitignored and should never be committed.

# ─── Build / image versions ────────────────────────────────────────────────────
# Version tag applied to all openclaw images (base + gateway)
OPENCLAW_VERSION=2026.5.27

# Go toolchain installed inside the gateway image (Dockerfile.gateway step 2)
GO_VERSION=1.26.3

# Name docker compose uses when tagging the locally built gateway image
OPENCLAW_IMAGE=openclaw-local

# Enable Docker Compose build delegation to BuildKit bake for faster image builds.
# This suppresses the informational prompt about bake and keeps build invocation simple.
COMPOSE_BAKE=1

# Base image for Dockerfile.gateway:
#   Official release (default):  OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw
#   Locally-built patched image: OPENCLAW_BASE_IMAGE=openclaw-patched
OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw

# ClawHub CLI and Skill versions
CLAWHUB_CLI_VERSION=latest
CLAWHUB_GITHUB_SKILL_VERSION=1.0.0
CLAWHUB_BROWSER_USE_SKILL_VERSION=2.0.1
CLAWHUB_AGENT_BROWSER_SKILL_VERSION=0.1.0

# Build-time package versions
QCARD_VERSION=v0.0.0-20250207202606-8b7c0bd90f21

# ─── Runtime flags ─────────────────────────────────────────────────────────────
OPENCLAW_NO_RESPAWN=1
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_DISABLE_BONJOUR=1

# ─── Host / external paths ─────────────────────────────────────────────────────
# These are host-side paths used by Docker compose and bind mounts.
#
# OPENCLAW_CONFIG_DIR / OPENCLAW_WORKSPACE_DIR — host-side location of the
# persistent OpenClaw config tree. The container always sees this as
# /home/node/.openclaw regardless of where it lives on the host.
#
# Default (running as root):
#   OPENCLAW_CONFIG_DIR=/root/.openclaw
#   OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
#
# This deployment uses a dedicated system user `shelldon` (uid/gid 1000:1000,
# matching the container's `node` user) so the config tree lives under
# shelldon's home directory. This avoids root-owned files in the config dir
# and allows direct SSH access as `shelldon` without permission issues.
#
# If you run as root, revert both paths to /root/.openclaw[/workspace].
OPENCLAW_CONFIG_DIR=/home/shelldon/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/shelldon/.openclaw/workspace
OPENCLAW_BACKUP_DIR=/mnt/openclaw-backup
NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
STAGED_SKILLS_DIR=/opt/openclaw-skills-seed

# ─── Additional private mounts / shares ───────────────────────────────────────
# Host-side paths for optional private mounts or external shares.
NEXTCLOUD_DOCUMENTS_DIR=/mnt/nextcloud/Documents

# ─── Container / OpenClaw paths ────────────────────────────────────────────────
# These are the runtime paths visible inside the openclaw-gateway container.
OPENCLAW_DIR=/home/node/.openclaw
OPENCLAW_BUNDLED_PLUGINS_DIR=/app/dist/extensions
XDG_CONFIG_HOME=/home/node/.config

# ─── Vaultwarden secrets provider ──────────────────────────────────────────────
# OpenClaw uses the Bitwarden CLI (bw) to fetch secrets from your self-hosted
# Vaultwarden vault at container startup. Instead of your regular email/password
# login, you create a dedicated API key — this is safer for automation because:
#   • No 2FA prompts (bw --apikey login is non-interactive)
#   • Purpose-limited credential (can be revoked independently)
#   • Your real password is never used for the login step, only for vault unlock
#
# ── How to create the API key in Vaultwarden ──────────────────────────────────
# 1. Log in to your Vaultwarden web vault (e.g. https://vault.example.com)
# 2. Go to: Account Settings → Security → Keys → API Key
# 3. Click "View API Key" (and confirm with your master password)
# 4. You will see three values — copy them into your .env file:
#
#      client_id     → BW_CLIENTID      (format: user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
#      client_secret → BW_CLIENTSECRET  (a random alphanumeric string)
#
# 5. BW_PASSWORD is still your regular Vaultwarden master password.
#    The API key handles the *login* step; the master password is required
#    separately to *unlock* the encrypted vault data.
#
# ── Variable reference ────────────────────────────────────────────────────────
# BW_SERVER_URL   — Full URL of your Vaultwarden instance (no trailing slash)
#                   Example: https://vault.example.com
# BW_CLIENTID     — API client_id from the API Key dialog
#                   Example: user.3f4a1b2c-5d6e-7f8a-9b0c-1d2e3f4a5b6c
# BW_CLIENTSECRET — API client_secret from the same dialog (long random string)
# BW_PASSWORD     — Your Vaultwarden account master password (used only to unlock)
#
# Leave all four empty to disable the Vaultwarden provider entirely.
BW_SERVER_URL=https://vault.domain.tld
BW_CLIENTID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BW_CLIENTSECRET=<long-random-secret>
BW_PASSWORD=<your-master-password>

#################################################################################
#################################################################################
# ─── Secrets  / Your API Keys ───────────────────────────────────────────────────────
#################################################################################

# OpenClaw gateway bearer token — choose any strong random string.
# Generate one with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw web UI password — choose any strong passphrase.
GATEWAY_AUTH_PASSWORD=

# ─── External API keys ─────────────────────────────────────────────────────────

# Telegram bot token — obtained from @BotFather on Telegram.
# Start a chat with @BotFather, send /newbot, follow the prompts.
# Result looks like: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_TOKEN=

# Discord bot token — obtained from the Discord Developer Portal.
# Go to https://docs.openclaw.ai/channels/discord#quick-setup
# Create an application, add a bot, copy the token, and invite it to your server.
DISCORD_BOT_TOKEN=

# Google Gemini API key — obtain at https://aistudio.google.com/apikey
# No credit card required for the free tier.
GEMINI_API_KEY=

# ─── GitHub Tokens ─────────────────────────────────────────────────────────────

# GitHub Personal Access Token (PAT) — used by the gh CLI tool.
#
# How to create one:
#   https://github.com/settings/tokens → Generate new token (classic)
#
# Required scopes:
#   repo, read:user, gist
#
# The token typically looks like: ghp_...
GITHUB_TOKEN=

# GitHub Copilot OAuth user token — used to access your Copilot subscription.
# This is NOT a PAT; it must be obtained via OAuth device flow.
#
# Easiest way to get one:
#   gh auth login --scopes copilot
#   gh auth token
#
# Alternatively, via OAuth device flow against your registered GitHub OAuth App:
#   https://docs.github.com/en/apps/oauth-apps/building-oauth-apps/authorizing-oauth-apps#device-flow
#
# Required scope: copilot
#
# The token typically looks like: ghu_...
COPILOT_GITHUB_TOKEN=

# OpenRouter API key — obtain at https://openrouter.ai
# Provides access to many models (OpenAI, Anthropic, Mistral, etc.) via one key.
OPENROUTER_API_KEY=

# NVIDIA NIM API key — obtain at https://build.nvidia.com
NVIDIA_API_KEY=

# OpenCode API key — obtain at https://opencode.ai
OPENCODE_API_KEY=
